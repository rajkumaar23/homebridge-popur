{
  "displayName": "Homebridge Popur",
  "name": "homebridge-popur",
  "version": "0.1.4",
  "description": "Homebridge plugin for Popur self-cleaning cat litter boxes (e.g. the X5) via the Popur cloud.",
  "license": "MIT",
  "author": "rajkumaar23",
  "type": "commonjs",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajkumaar23/homebridge-popur.git"
  },
  "bugs": {
    "url": "https://github.com/rajkumaar23/homebridge-popur/issues"
  },
  "homepage": "https://github.com/rajkumaar23/homebridge-popur#readme",
  "engines": {
    "homebridge": "^1.6.0 || ^2.0.0-beta.0",
    "node": "^18.20.0 || ^20.9.0 || ^22.0.0 || ^24.0.0"
  },
  "files": [
    "dist",
    "config.schema.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
